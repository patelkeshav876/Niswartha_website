# Visit booking email notifications
# If SMTP_* are not set, server auto-uses Ethereal test SMTP and only preview URLs are generated.
VISIT_ADMIN_EMAIL=admin@ddschool.org
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ddschool.org

# Gmail SMTP (recommended for personal sender accounts)
# 1) Turn on 2-Step Verification in Google account
# 2) Generate an App Password and use it as SMTP_PASS
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=yourgmail@gmail.com

# Zoho SMTP (recommended for business/domain mailboxes)
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=your_zoho_app_password
# SMTP_FROM=you@yourdomain.com
